<h3 class="text-xl font-bold text-gray-800 mb-4">Create New Event</h3>\
<form action="/m/event/create" method="POST" name="new_event" onsubmit="return validateCreateEventForm();"\
      class="space-y-5">\
\
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-2xl">\
    <div>\
      <label class="block text-xs text-gray-600 mb-1" for="event_date">Date &amp; Time <span class="text-gray-400">(YYYY-MM-DD HH:MM)</span></label>\
      <input class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"\
             type="text" name="event_date" id="event_date" value="<%= Time.now.strftime("%Y-%m-%d %H:%M") %>" />\
    </div>\
    <div>\
      <label class="block text-xs text-gray-600 mb-1" for="type">Event Type <span class="text-red-500">*</span></label>\
      <select id="type" name="event_type_id"\
              class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">\
        <option value="none" selected>Select event type</option>\
        <% @event_types.each do |event_type| %>\
        <option value="<%= event_type[:id] %>"><%= event_type[:name] %></option>\
        <% end %>\
      </select>\
    </div>\
    <div>\
      <label class="block text-xs text-gray-600 mb-1" for="new_type_name">Event Name</label>\
      <input class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"\
             type="text" name="name" id="new_type_name" />\
    </div>\
    <div>\
      <label class="block text-xs text-gray-600 mb-1">Description</label>\
      <input class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"\
             type="text" name="descr" />\
    </div>\
    <div>\
      <label class="block text-xs text-gray-600 mb-1" for="duration">Duration</label>\
      <div class="flex items-center gap-3">\
        <select name="duration" id="duration"\
                class="border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">\
          <option>none</option>\
          <% 5.times do |t| %><option><%= t + 1 %></option><% end %>\
        </select>\
        <span class="text-sm text-gray-600">\
          <label class="inline-flex items-center gap-1">\
            <input type="radio" name="duration_units" id="durat_hrs" value="hrs" class="w-auto" /> Hours\
          </label>\
          &nbsp;\
          <label class="inline-flex items-center gap-1">\
            <input type="radio" name="duration_units" id="durat_days" value="days" class="w-auto" /> Days\
          </label>\
        </span>\
      </div>\
    </div>\
\
    <!-- Event contact search -->\
    <div>\
      <label class="block text-xs text-gray-600 mb-1" for="contact_search">\
        Event Contact / Organizer <span class="text-red-500">*</span>\
        <span class="text-gray-400 font-normal">&mdash; type last name or callsign</span>\
      </label>\
      <input type="text" id="contact_search" list="members-datalist" autocomplete="off"\
             placeholder="e.g. Smith or KD7ABC"\
             class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />\
      <datalist id="members-datalist">\
        <% @mbrs.each do |m| %>\
        <option value="<%= "#\{m[:lname]\}, #\{m[:fname]\} (#\{m[:callsign]\})" %>"></option>\
        <% end %>\
      </datalist>\
      <input type="hidden" name="mbr_id" id="mbr_id" />\
    </div>\
  </div>\
\
  <div class="max-w-2xl">\
    <label class="block text-xs text-gray-600 mb-1" for="general_notes">Notes for log</label>\
    <textarea name="general_notes" id="general_notes" rows="4"\
              class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"></textarea>\
  </div>\
\
  <!-- Guest attendees -->\
  <div class="max-w-2xl">\
    <label class="block text-xs text-gray-600 mb-1" for="guest_notes">\
      Low-probability guest attendees <span class="text-gray-400">(separated by semicolon, no spaces: &apos;Guest,First;Guest,Second&apos;)</span>\
    </label>\
    <textarea name="guest_notes" id="guest_notes" rows="3"\
              class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"></textarea>\
    <label class="flex items-center gap-2 text-sm mt-2">\
      <input type="checkbox" name="has_guests" onchange="guestsSet(this)" class="w-auto" />\
      There are guests to add to the database\
    </label>\
  </div>\
\
  <!-- Guest data entry table \'97 JS-controlled visibility via id="message" -->\
  <div id="message" class="max-w-4xl">\
    <p class="text-xs text-gray-500 mb-2">At least two of the four fields (not including notes) must be filled out per guest.</p>\
    <div class="overflow-x-auto">\
      <table class="w-full border-collapse text-sm">\
        <thead>\
          <tr class="bg-gray-100 text-left">\
            <th class="border border-gray-300 px-2 py-1">First Name</th>\
            <th class="border border-gray-300 px-2 py-1">Last Name</th>\
            <th class="border border-gray-300 px-2 py-1">Callsign</th>\
            <th class="border border-gray-300 px-2 py-1">Email</th>\
            <th class="border border-gray-300 px-2 py-1">Notes</th>\
          </tr>\
        </thead>\
        <tbody>\
          <% count = 0 %>\
          <% 5.times do %>\
          <tr class="odd:bg-white even:bg-gray-50">\
            <td class="border border-gray-200 px-1 py-0.5"><input class="w-full border border-gray-300 rounded px-2 py-1 text-xs" type="text" name="<%= "g#\{count\}:fname" %>" value="*guest first name" onclick="this.select();" /></td>\
            <td class="border border-gray-200 px-1 py-0.5"><input class="w-full border border-gray-300 rounded px-2 py-1 text-xs" type="text" name="<%= "g#\{count\}:lname" %>" value="*guest last name" onclick="this.select();" /></td>\
            <td class="border border-gray-200 px-1 py-0.5"><input class="w-full border border-gray-300 rounded px-2 py-1 text-xs" type="text" name="<%= "g#\{count\}:callsign" %>" value="*guest callsign" onclick="this.select();" /></td>\
            <td class="border border-gray-200 px-1 py-0.5"><input class="w-full border border-gray-300 rounded px-2 py-1 text-xs guestEmail" type="text" name="<%= "g#\{count\}:email" %>" value="*guest email" onclick="this.select();" /></td>\
            <td class="border border-gray-200 px-1 py-0.5"><textarea class="w-full border border-gray-300 rounded px-2 py-1 text-xs" name="<%= "g#\{count\}:notes" %>" rows="2" onclick="this.select();">*guest notes</textarea></td>\
          </tr>\
          <% count += 1 %>\
          <% end %>\
        </tbody>\
      </table>\
    </div>\
  </div>\
\
  <!-- Member attendance table -->\
  <div>\

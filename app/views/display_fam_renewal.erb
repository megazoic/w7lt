<h3 class="text-xl font-bold text-gray-800 mb-1">Family Units &amp; Renewal Dates</h3>
<p class="text-xs text-gray-500 mb-4">*Active: has at least 2 members (regardless of payment status)</p>

<div class="overflow-x-auto">
  <table class="w-full border-collapse text-sm">
    <thead>
      <tr class="bg-gray-100 text-left">
        <th class="border border-gray-300 px-2 py-1">Unit ID</th>
        <th class="border border-gray-300 px-2 py-1">*Active</th>
        <th class="border border-gray-300 px-2 py-1">Mbr ID</th>
        <th class="border border-gray-300 px-2 py-1">First</th>
        <th class="border border-gray-300 px-2 py-1">Last</th>
        <th class="border border-gray-300 px-2 py-1 whitespace-nowrap">Renewal Date</th>
      </tr>
    </thead>
    <tbody>
      <% @fam_mbrship_details.each do |fd| %>
      <% row_no = 0 %>
      <% fd[:mbrs].each do |d| %>
      <tr class="odd:bg-white even:bg-gray-50">
        <td class="border border-gray-200 px-2 py-0.5"><%= row_no == 0 ? fd[:unit_id] : '' %></td>
        <td class="border border-gray-200 px-2 py-0.5"><%= row_no == 0 ? fd[:active] : '' %></td>
        <td class="border border-gray-200 px-2 py-0.5"><%= d[0] %></td>
        <td class="border border-gray-200 px-2 py-0.5"><%= d[1] %></td>
        <td class="border border-gray-200 px-2 py-0.5"><%= d[2] %></td>
        <td class="border border-gray-200 px-2 py-0.5 whitespace-nowrap <%= d[4] == true ? 'renew' : '' %>"><%= d[3] %></td>
      </tr>
      <% row_no += 1 %>
      <% end %>
      <% end %>
    </tbody>
  </table>
</div>

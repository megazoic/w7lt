<h3 class="text-xl font-bold text-gray-800 mb-1">Set Role</h3>
<p class="text-sm text-gray-600 mb-4">
  <strong><%= "#{@sel_au_mbr[:fname]} #{@sel_au_mbr[:lname]}, #{@sel_au_mbr[:callsign]}" %></strong>
  &mdash; <%= @sel_au_mbr[:email] %>
</p>
<p class="text-xs text-gray-500 mb-4">Roles are hierarchical — a role includes all roles of lower rank.</p>

<form action="/a/auth_user/create" method="POST" name="auRoles" onsubmit="return validateAssignRoleForm();"
      class="space-y-4 max-w-md">
  <input type="hidden" name="mbr_id" value="<%= @sel_au_mbr[:id] %>">

  <fieldset class="border border-gray-200 rounded p-4 space-y-2">
    <legend class="text-xs font-semibold text-gray-600 px-1">Role</legend>
    <% @roles.each do |role| %>
    <label class="flex items-center gap-2 text-sm">
      <input type="radio" name="role_id" id="role_<%= role[:id] %>" value="<%= role[:id] %>" class="w-auto" />
      <%= role[:description] %> <span class="text-xs text-gray-400">(rank: <%= ['hi', 'med', 'lo'][role[:rank]] %>)</span>
    </label>
    <% end %>
  </fieldset>

  <div>
    <label class="block text-xs text-gray-600 mb-1" for="notes_field">Notes</label>
    <textarea name="notes" id="notes_field" rows="3"
              class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"></textarea>
  </div>

  <div>
    <input type="submit" value="Submit"
           class="bg-green-600 hover:bg-green-700 text-white text-sm font-medium px-5 py-2 rounded cursor-pointer" />
  </div>
</form>

<h3 class="text-xl font-bold text-gray-800 mb-1">Membership Report</h3>
<% if @report_label %>
<p class="text-sm text-gray-500 mb-4"><%= @report_label %></p>
<% end %>

<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6 max-w-2xl">
  <div class="border border-gray-200 rounded p-4">
    <h4 class="text-xs font-semibold text-gray-500 uppercase mb-2">ARRL</h4>
    <dl class="space-y-1 text-sm">
      <div class="flex justify-between"><dt>ARRL member</dt><dd class="font-medium"><%= @rpt[:arrl] %></dd></div>
      <div class="flex justify-between"><dt>Not ARRL</dt><dd class="font-medium"><%= @rpt[:not_arrl] %></dd></div>
      <div class="flex justify-between border-t border-gray-100 pt-1"><dt class="font-semibold">Total</dt><dd class="font-bold"><%= @rpt[:total] %></dd></div>
    </dl>
  </div>

  <div class="border border-gray-200 rounded p-4">
    <h4 class="text-xs font-semibold text-gray-500 uppercase mb-2">License Class</h4>
    <dl class="space-y-1 text-sm">
      <div class="flex justify-between"><dt>None</dt><dd class="font-medium"><%= @rpt[:lic_none] %></dd></div>
      <div class="flex justify-between"><dt>Tech</dt><dd class="font-medium"><%= @rpt[:lic_tech] %></dd></div>
      <div class="flex justify-between"><dt>General</dt><dd class="font-medium"><%= @rpt[:lic_gen] %></dd></div>
      <div class="flex justify-between"><dt>Extra</dt><dd class="font-medium"><%= @rpt[:lic_extra] %></dd></div>
      <div class="flex justify-between"><dt>GMRS</dt><dd class="font-medium"><%= @rpt[:lic_GMRS] %></dd></div>
    </dl>
  </div>

  <div class="border border-gray-200 rounded p-4">
    <h4 class="text-xs font-semibold text-gray-500 uppercase mb-2">Member Type</h4>
    <dl class="space-y-1 text-sm">
      <div class="flex justify-between"><dt>Lifetime</dt><dd class="font-medium"><%= @rpt[:type_lifetime] %></dd></div>
      <div class="flex justify-between"><dt>Full</dt><dd class="font-medium"><%= @rpt[:type_full] %></dd></div>
      <div class="flex justify-between"><dt>Family</dt><dd class="font-medium"><%= @rpt[:type_family] %></dd></div>
      <div class="flex justify-between"><dt>Student</dt><dd class="font-medium"><%= @rpt[:type_student] %></dd></div>
      <div class="flex justify-between"><dt>Honorary</dt><dd class="font-medium"><%= @rpt[:type_honorary] %></dd></div>
    </dl>
  </div>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-2xl">
  <div>
    <h4 class="text-sm font-semibold text-gray-700 mb-2">Voting Members with Email</h4>
    <ul class="text-sm space-y-0.5">
      <% @voting_email.each do |ve| %>
      <li class="text-gray-800"><%= ve %></li>
      <% end %>
    </ul>
  </div>
  <div>
    <h4 class="text-sm font-semibold text-gray-700 mb-2">Voting Members without Email</h4>
    <ul class="text-sm space-y-0.5">
      <% @voting_other.each do |vo| %>
      <li class="text-gray-800"><%= vo %></li>
      <% end %>
    </ul>
  </div>
</div>

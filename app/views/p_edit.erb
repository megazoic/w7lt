<h3 class="text-xl font-bold text-gray-800 mb-4">Edit Payment</h3>
<p class="text-sm text-gray-600 mb-4">
  Member: <strong><%= "#{@mbr[:fname]} #{@mbr[:lname]}" %></strong> (<%= @mbr[:callsign] %>) &mdash; Type: <%= @mbr[:mbr_type] %>
</p>

<form action="/m/payments/edit" method="POST" name="mbrPay" class="space-y-4 max-w-lg">
  <input type="hidden" name="pay_id" value="<%= @pay[:id] %>">
  <input type="hidden" name="pay_log_id" value="<%= @log[:id] %>">

  <div>
    <label class="block text-xs text-gray-600 mb-1" for="payment_type_field">Payment Type</label>
    <select name="payment_type" id="payment_type_field"
            class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      <% @payType.each do |t| %>
      <option value="<%= t.values[:id] %>"<%= @pay[:payment_type_id] == t.values[:id] ? ' selected' : '' %>><%= t.values[:type] %></option>
      <% end %>
    </select>
  </div>

  <div>
    <label class="block text-xs text-gray-600 mb-1" for="payment_method_field">Payment Method</label>
    <select name="payment_method" id="payment_method_field"
            class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      <% @payMethod.each do |m| %>
      <option value="<%= m.values[:id] %>"<%= @pay[:payment_method_id] == m.values[:id] ? ' selected' : '' %>><%= m.values[:mode] %></option>
      <% end %>
    </select>
  </div>

  <div>
    <label class="block text-xs text-gray-600 mb-1" for="payment_amt_field">Payment Amount <span class="text-gray-400">(e.g. 23 or 23.00)</span></label>
    <input type="text" name="payment_amt" id="payment_amt_field" value="<%= @pay[:payment_amount] %>"
           onfocusout="validatePayAmt(this)"
           class="border border-gray-300 rounded px-3 py-1.5 text-sm w-28 focus:outline-none focus:ring-2 focus:ring-blue-500" />
  </div>

  <div>
    <label class="block text-xs text-gray-600 mb-1" for="notes_field">Notes</label>
    <textarea name="notes" id="notes_field" rows="6"
              class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"><%= @log[:notes] %></textarea>
  </div>

  <div class="flex items-center gap-4">
    <input type="submit" value="Submit" onsubmit="validateMbrPayForm();"
           class="bg-green-600 hover:bg-green-700 text-white text-sm font-medium px-5 py-2 rounded cursor-pointer" />
    <a href="/r/member/list" class="text-sm text-gray-500 hover:underline">Cancel</a>
  </div>
</form>

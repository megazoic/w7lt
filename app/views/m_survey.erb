<h3 class="text-xl font-bold text-gray-800 mb-4">Member Survey</h3>

<form action="/r/member/mbr_survey" method="POST" class="space-y-6 max-w-lg">
  <% titles = ["Topics", "Frequencies", "Modes", "Callback"] %>
  <% @codes.each do |codegroup| %>
  <fieldset class="border border-gray-200 rounded p-4">
    <legend class="text-sm font-semibold text-gray-700 px-1"><%= titles.shift %></legend>
    <div class="space-y-1 mt-1">
      <% codegroup.each do |k, v| %>
      <label class="flex items-center gap-2 text-sm">
        <input type="checkbox" id="<%= k %>" name="<%= k %>" value="1" class="w-auto" />
        <%= v %> <span class="text-xs text-gray-400">(<%= @response_tally[k] %>)</span>
      </label>
      <% end %>
    </div>
  </fieldset>
  <% end %>

  <% if !@other_choices.empty? %>
  <div>
    <h4 class="text-sm font-semibold text-gray-700 mb-1">Other Choices</h4>
    <p class="text-sm text-gray-600 whitespace-pre-wrap"><%= @other_choices %></p>
  </div>
  <% end %>

  <div class="flex items-center gap-4">
    <input type="submit" value="Submit"
           class="bg-green-600 hover:bg-green-700 text-white text-sm font-medium px-5 py-2 rounded cursor-pointer" />
    <a href="/r/member/list" class="text-sm text-gray-500 hover:underline">Cancel</a>
  </div>
</form>

<h2 class="text-xl font-bold text-gray-800 mb-1">Frequent Attendees</h2>
<p class="text-sm text-gray-500 mb-4">Members with the most event attendance in the last 6 months, since <%= @cutoff_date.strftime('%B %d, %Y') %>.</p>

<% if @frequent_attendees.empty? %>
<p class="text-gray-500 text-sm">No attendance data found for this period.</p>
<% else %>
<div class="overflow-x-auto">
  <table class="w-full border-collapse text-sm">
    <thead>
      <tr class="bg-gray-100 text-left">
        <th class="border border-gray-300 px-2 py-1">Name</th>
        <th class="border border-gray-300 px-2 py-1 whitespace-nowrap">Callsign</th>
        <th class="border border-gray-300 px-2 py-1 whitespace-nowrap text-center">Events</th>
        <th class="border border-gray-300 px-2 py-1 whitespace-nowrap">Most Recent Event Type</th>
      </tr>
    </thead>
    <tbody>
      <% @frequent_attendees.each do |a| %>
      <tr class="odd:bg-white even:bg-gray-50">
        <td class="border border-gray-200 px-2 py-0.5 whitespace-nowrap">
          <a href="/r/member/show/<%= a[:mbr_id] %>" class="text-blue-600 hover:underline">
            <%= a[:fname] %> <%= a[:lname] %>
          </a>
        </td>
        <td class="border border-gray-200 px-2 py-0.5 whitespace-nowrap"><%= a[:callsign] %></td>
        <td class="border border-gray-200 px-2 py-0.5 text-center font-medium"><%= a[:event_count] %></td>
        <td class="border border-gray-200 px-2 py-0.5 whitespace-nowrap">
          <% if a[:latest_event_id] %>
          <a href="/m/event/attendees/show/<%= a[:latest_event_id] %>" class="text-blue-600 hover:underline">
            <%= a[:latest_event_type] %>
          </a>
          <% else %>
          &mdash;
          <% end %>
        </td>
      </tr>
      <% end %>
    </tbody>
  </table>
</div>
<% end %>

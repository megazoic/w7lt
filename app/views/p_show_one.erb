<h3 class="text-xl font-bold text-gray-800 mb-4">Payment Details</h3>
<div class="max-w-md space-y-4">
  <div class="bg-white border border-gray-200 rounded p-4 text-sm space-y-2">
    <div class="flex gap-2">
      <span class="text-gray-500 w-36 shrink-0">Payment ID</span>
      <span class="font-medium"><%= @pay[:id] %></span>
    </div>
    <div class="flex gap-2">
      <span class="text-gray-500 w-36 shrink-0">Member</span>
      <span><%= "#{@mbr[:fname]} #{@mbr[:lname]}" %> (<%= @mbr[:callsign] %>)</span>
    </div>
    <div class="flex gap-2">
      <span class="text-gray-500 w-36 shrink-0">Member Type</span>
      <span><%= @mbr[:mbr_type] %></span>
    </div>
    <div class="flex gap-2">
      <span class="text-gray-500 w-36 shrink-0">Payment Type</span>
      <span><%= @pay[:payment_type] %></span>
    </div>
    <div class="flex gap-2">
      <span class="text-gray-500 w-36 shrink-0">Payment Method</span>
      <span><%= @pay[:payment_method] %></span>
    </div>
    <div class="flex gap-2">
      <span class="text-gray-500 w-36 shrink-0">Amount</span>
      <span class="font-medium">$<%= @pay[:payment_amount] %></span>
    </div>
  </div>

  <div>
    <h4 class="text-sm font-semibold text-gray-700 mb-1">Log Notes</h4>
    <div class="bg-white border border-gray-200 rounded p-3 text-sm text-gray-800 whitespace-pre-wrap"><%= @log[:notes] %></div>
  </div>
</div>

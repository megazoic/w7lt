<h3 class="text-xl font-bold text-gray-800 mb-4">Add Note to Member Action</h3>

<div class="max-w-lg space-y-1 text-sm mb-6">
  <div class="flex gap-2">
    <span class="text-gray-500 w-24 shrink-0">Member</span>
    <span class="font-medium"><%= @mbr_action[:target_member_name] %></span>
  </div>
  <div class="flex gap-2">
    <span class="text-gray-500 w-24 shrink-0">Description</span>
    <span><%= @mbr_action[:notes] %></span>
  </div>
  <div class="flex gap-2">
    <span class="text-gray-500 w-24 shrink-0">Tasked To</span>
    <span><%= @mbr_action[:tasked_to_mbr_name] %></span>
  </div>
</div>

<div class="max-w-lg mb-6">
  <h4 class="text-sm font-semibold text-gray-700 mb-2">Previous Log Notes</h4>
  <% if @logs && @logs.any? %>
  <div class="space-y-3">
    <% @logs.each do |log| %>
    <div class="border border-gray-200 rounded p-3 text-sm bg-white">
      <p class="text-xs text-gray-400 mb-1"><%= log[:ts].strftime("%m/%d/%Y") if log[:ts] %></p>
      <!-- notes contain pre-rendered <br> tags from the route -->
      <p class="text-gray-800"><%= log[:notes] %></p>
    </div>
    <% end %>
  </div>
  <% else %>
  <p class="text-sm text-gray-500">No previous log notes.</p>
  <% end %>
</div>

<div class="max-w-lg">
  <h4 class="text-sm font-semibold text-gray-700 mb-2">Add Log Note</h4>
  <form action="/m/member_action/add_note" method="POST" class="space-y-3">
    <input type="hidden" name="mbr_action_id" value="<%= @mbr_action[:id] %>">
    <textarea name="note" rows="4" placeholder="Enter additional log note here"
              class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"></textarea>
    <div class="flex items-center gap-4">
      <button type="submit"
              class="bg-green-600 hover:bg-green-700 text-white text-sm font-medium px-5 py-2 rounded cursor-pointer">
        Add Note
      </button>
      <a href="/m/followup/show" class="text-sm text-gray-500 hover:underline">Cancel</a>
    </div>
  </form>
</div>

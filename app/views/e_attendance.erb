<h2 class="text-xl font-bold text-gray-800 mb-4">Attendance Report</h2>
<% if @attendance_data && !@attendance_data.empty? %>
<div class="overflow-x-auto">
  <table class="w-full border-collapse text-sm">
    <thead>
      <tr class="bg-gray-100 text-left">
        <th class="border border-gray-300 px-2 py-1 whitespace-nowrap">Event Date</th>
        <th class="border border-gray-300 px-2 py-1 whitespace-nowrap"># Hybrid</th>
        <th class="border border-gray-300 px-2 py-1 whitespace-nowrap"># In-Person</th>
        <th class="border border-gray-300 px-2 py-1 whitespace-nowrap"># Online</th>
        <th class="border border-gray-300 px-2 py-1 whitespace-nowrap">Total</th>
        <th class="border border-gray-300 px-2 py-1">Name &amp; Description</th>
        <th class="border border-gray-300 px-2 py-1"></th>
      </tr>
    </thead>
    <tbody>
      <% @attendance_data.each do |event_date, data| %>
      <tr class="odd:bg-white even:bg-gray-50">
        <td class="border border-gray-200 px-2 py-0.5 whitespace-nowrap"><%= event_date %></td>
        <td class="border border-gray-200 px-2 py-0.5 text-center"><%= data[:old_format] %></td>
        <td class="border border-gray-200 px-2 py-0.5 text-center"><%= data[:inperson] %></td>
        <td class="border border-gray-200 px-2 py-0.5 text-center"><%= data[:zoom] %></td>
        <td class="border border-gray-200 px-2 py-0.5 text-center font-medium"><%= data[:event_date_total] %></td>
        <td class="border border-gray-200 px-2 py-0.5"><%= data[:name] %> &mdash; <%= data[:descr] %></td>
        <td class="border border-gray-200 px-2 py-0.5 whitespace-nowrap">
          <a href="/m/event/attendees/show/<%= data[:event_id] %>" class="text-blue-600 hover:underline text-xs">Details</a>
        </td>
      </tr>
      <% end %>
    </tbody>
  </table>
</div>
<% else %>
<p class="text-gray-500 text-sm">No attendance data available for the selected event type.</p>
<% end %>

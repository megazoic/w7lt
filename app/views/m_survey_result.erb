<h3 class="text-xl font-bold text-gray-800 mb-4">Survey Results</h3>

<div class="overflow-x-auto mb-4">
  <table class="border-collapse text-sm">
    <tbody>
      <% @responses_selected_display.each do |rs| %>
      <tr class="odd:bg-white even:bg-gray-50">
        <% rs.each do |r| %>
        <td class="border border-gray-200 px-2 py-0.5"><%= r %></td>
        <% end %>
      </tr>
      <% end %>
    </tbody>
  </table>
</div>

<hr class="border-gray-200 mb-4" />

<div class="overflow-x-auto mb-6">
  <table class="w-full border-collapse text-sm">
    <thead>
      <tr class="bg-gray-100 text-left">
        <th class="border border-gray-300 px-2 py-1">First</th>
        <th class="border border-gray-300 px-2 py-1">Last</th>
        <th class="border border-gray-300 px-2 py-1">Call</th>
        <th class="border border-gray-300 px-2 py-1 whitespace-nowrap">Renewal Date</th>
        <th class="border border-gray-300 px-2 py-1">Email</th>
        <th class="border border-gray-300 px-2 py-1 whitespace-nowrap">Mbr Since</th>
        <th class="border border-gray-300 px-2 py-1"></th>
      </tr>
    </thead>
    <tbody>
      <% @mbrs_in_survey.each do |mbr| %>
      <tr class="odd:bg-white even:bg-gray-50">
        <td class="border border-gray-200 px-2 py-0.5 whitespace-nowrap"><%= mbr[:fname] %></td>
        <td class="border border-gray-200 px-2 py-0.5 whitespace-nowrap"><%= mbr[:lname] %></td>
        <td class="border border-gray-200 px-2 py-0.5 whitespace-nowrap"><%= mbr[:callsign] %></td>
        <td class="border border-gray-200 px-2 py-0.5 whitespace-nowrap"><%= mbr[:ren_date] %></td>
        <td class="border border-gray-200 px-2 py-0.5"><%= mbr[:email] %></td>
        <td class="border border-gray-200 px-2 py-0.5 whitespace-nowrap"><%= mbr[:mbr_since] %></td>
        <td class="border border-gray-200 px-2 py-0.5 whitespace-nowrap text-xs">
          <a href="/r/member/show/<%= mbr[:mbr_id] %>" class="text-blue-600 hover:underline">Mbr</a> |
          <a href="/r/log/logNote/show/<%= mbr[:log_id] %>" class="text-blue-600 hover:underline">Log</a>
        </td>
      </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div>
  <h4 class="text-sm font-semibold text-gray-700 mb-1">Email List</h4>
  <textarea id="text-box" rows="3"
            class="w-full max-w-2xl border border-gray-300 rounded px-3 py-2 text-sm"><%= @emails[0...-2] %></textarea>
  <button onclick="selectText();"
          class="mt-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm px-4 py-1.5 rounded border border-gray-300">
    Select Emails
  </button>
</div>

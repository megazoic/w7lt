<h1 class="text-2xl font-bold text-gray-800 mb-1">PARC Home</h1>
<p class="text-sm text-gray-600 mb-4">Select a route from the links above or choose a member below.</p>
<div class="grid grid-cols-3 gap-x-4 gap-y-0.5 text-sm">
  <% @member_lnames.each do |member| %>
  <a href="/r/member/show/<%= member.id %>" class="text-blue-600 hover:underline truncate py-0.5">
    <%= member.lname %>
  </a>
  <% end %>
</div>

<h3 class="text-xl font-bold text-gray-800 mb-1">Update Role</h3>
<p class="text-sm text-gray-600 mb-1">
  <strong><%= "#{@mbr_to_update[:fname]} #{@mbr_to_update[:lname]}, #{@mbr_to_update[:callsign]}" %></strong>
  &mdash; <%= @mbr_to_update[:email] %>
</p>
<p class="text-sm text-gray-700 mb-4">
  Status: <strong><%= @mbr_to_update[:role].name != "inactive" ? "Active" : "Inactive" %></strong>
</p>
<p class="text-xs text-gray-500 mb-4">Roles are hierarchical — a role includes all roles of lower rank.</p>

<form action="/a/auth_user/update" method="POST" name="auRoles" onsubmit="return validateAssignRoleForm();"
      class="space-y-4 max-w-md">
  <input type="hidden" name="mbr_id" value="<%= @mbr_to_update[:id] %>">

  <fieldset class="border border-gray-200 rounded p-4 space-y-2">
    <legend class="text-xs font-semibold text-gray-600 px-1">Role</legend>
    <% @au_roles.each do |role| %>
    <label class="flex items-center gap-2 text-sm">
      <input type="radio" name="role_id" value="<%= role[1] %>" class="w-auto"
             <%= @mbr_to_update[:role].id == role[1] ? 'checked' : '' %> />
      <%= role[2] %> <span class="text-xs text-gray-400">(rank: <%= ['hi', 'med', 'lo', 'none'][role[0]] %>)</span>
    </label>
    <% end %>
  </fieldset>

  <div>
    <label class="block text-xs text-gray-600 mb-1" for="notes_field">Notes</label>
    <textarea name="notes" id="notes_field" rows="3"
              class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"></textarea>
  </div>

  <div>
    <input type="submit" value="Submit"
           class="bg-green-600 hover:bg-green-700 text-white text-sm font-medium px-5 py-2 rounded cursor-pointer" />
  </div>
</form>

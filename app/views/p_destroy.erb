<h3 class="text-xl font-bold text-gray-800 mb-4">Delete Payment</h3>
<p class="text-sm text-gray-600 mb-4">
  Member: <strong><%= @payment.member.callsign %></strong>
</p>

<form action="/m/payments/destroy" method="POST" name="mbrPayDestroy" onsubmit="validatePayDestroy();"
      class="space-y-4 max-w-md">
  <input type="hidden" name="pay_id" value="<%= @payment[:id] %>">
  <input type="hidden" name="confirm" id="confirmIt" value="No">
  <input type="hidden" name="notes" value="">

  <div>
    <label class="block text-xs text-gray-600 mb-1" for="notes">Log Notes</label>
    <input type="text" name="notes" id="notes"
           class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
  </div>

  <div class="flex items-center gap-4">
    <input type="submit" value="Submit"
           class="bg-red-600 hover:bg-red-700 text-white text-sm font-medium px-5 py-2 rounded cursor-pointer" />
    <a href="/r/member/list" class="text-sm text-gray-500 hover:underline">Cancel</a>
  </div>
</form>

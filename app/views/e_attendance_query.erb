<h2 class="text-xl font-bold text-gray-800 mb-2">Attendance Query</h2>

<div id="wrong_choice" hidden class="mb-4 border border-red-400 bg-red-50 rounded p-3 text-sm text-red-700">
  <% if @no_data %>
  <p><%= @no_data %></p>
  <% end %>
</div>

<form action="/r/event/attendance" method="post" class="space-y-4 max-w-sm">
  <fieldset>
    <legend class="text-sm font-semibold text-gray-700 mb-2">Report Type</legend>
    <div class="space-y-1 text-sm text-gray-700">
      <label class="flex items-center gap-2">
        <input type="radio" name="query_type" value="by_type" checked class="w-auto"
               onchange="toggleEventTypes()" />
        By event type
      </label>
      <label class="flex items-center gap-2">
        <input type="radio" name="query_type" value="frequent" class="w-auto"
               onchange="toggleEventTypes()" />
        Frequent attendees &mdash; over the last 6 months
      </label>
    </div>
  </fieldset>

  <div id="event_type_section">
    <p class="text-sm text-amber-700 font-medium mb-2">Note: Only general meetings are currently supported. Other event types will return no results.</p>
    <fieldset>
      <legend class="text-sm font-semibold text-gray-700 mb-2">Event Type</legend>
      <div class="space-y-1 text-sm text-gray-700">
        <% @event_types.each do |key, value| %>
        <label class="flex items-center gap-2">
          <input type="radio" id="et_<%= key %>" name="event_type_id" value="<%= key %>" class="w-auto" />
          <%= value %>
        </label>
        <% end %>
      </div>
    </fieldset>
  </div>

  <input type="submit" value="View Report"
         class="bg-green-600 hover:bg-green-700 text-white text-sm font-medium px-5 py-2 rounded cursor-pointer" />
</form>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    var firstRadio = document.querySelector('input[name="event_type_id"]');
    if (firstRadio) firstRadio.checked = true;
  });

  function toggleEventTypes() {
    var queryType = document.querySelector('input[name="query_type"]:checked').value;
    document.getElementById('event_type_section').style.display =
      queryType === 'frequent' ? 'none' : '';
  }

  document.querySelector('form[action="/r/event/attendance"]').addEventListener("submit", function(e) {
    var queryType = document.querySelector('input[name="query_type"]:checked').value;
    if (queryType === 'frequent') return;
    var selected = document.querySelector('input[name="event_type_id"]:checked');
    if (!selected || selected.value !== "1") {
      e.preventDefault();
      var warningDiv = document.getElementById("wrong_choice");
      warningDiv.hidden = false;
      warningDiv.innerHTML = "<p>Please select 'General Meeting' to view attendance data.</p>";
    }
  });
</script>

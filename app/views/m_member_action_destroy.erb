<h3 class="text-xl font-bold text-gray-800 mb-4">Confirm Delete Member Action</h3>

<div class="max-w-md space-y-1 text-sm mb-6">
  <div class="flex gap-2">
    <span class="text-gray-500 w-28 shrink-0">ID</span>
    <span><%= @member_action[:id] %></span>
  </div>
  <div class="flex gap-2">
    <span class="text-gray-500 w-28 shrink-0">Member</span>
    <span class="font-medium"><%= @member_action[:target_member_name] %></span>
  </div>
  <div class="flex gap-2">
    <span class="text-gray-500 w-28 shrink-0">Action Type</span>
    <span><%= @member_action[:member_action_type] %></span>
  </div>
  <div class="flex gap-2">
    <span class="text-gray-500 w-28 shrink-0">Notes</span>
    <span><%= @member_action[:notes] %></span>
  </div>
</div>

<form action="/m/mbr_non_renewals/destroy/<%= @member_action[:id] %>" method="POST"
      class="flex items-center gap-4">
  <input type="hidden" name="_method" value="delete" />
  <button type="submit"
          class="bg-red-600 hover:bg-red-700 text-white text-sm font-medium px-5 py-2 rounded cursor-pointer">
    Yes, Delete
  </button>
  <a href="/m/followup/show" class="text-sm text-gray-500 hover:underline">Cancel</a>
</form>

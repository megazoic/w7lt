<h2 class="text-xl font-bold text-gray-800 mb-4">PARC Membership Status Check</h2>
<p class="text-sm text-gray-600 mb-4">Use this form to check your current PARC membership status.</p>
<form action="status" method="POST" class="space-y-4">
  <div>
    <label class="block text-sm font-medium text-gray-700 mb-1" for="identifier_field">
      Callsign or first and last name
    </label>
    <input class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
           type="text" name="mbrIdentifier" id="identifier_field"
           onfocusout="validateMbrStatusIdentifier(this)" />
  </div>
  <div class="flex items-center gap-4">
    <input type="submit" value="Submit"
           class="bg-green-600 hover:bg-green-700 text-white text-sm font-medium px-5 py-2 rounded cursor-pointer" />
    <a href="/login" class="text-sm text-gray-500 hover:underline">Cancel</a>
  </div>
</form>

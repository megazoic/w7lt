<h3 class="text-xl font-bold text-gray-800 mb-4">Action: <%= @action_type[:callme][:descr] %></h3>
<div class="overflow-x-auto mb-8">
  <table class="w-full border-collapse text-sm">
    <thead>
      <tr class="bg-gray-100 text-left">
        <th class="border border-gray-300 px-2 py-1">Member</th>
        <th class="border border-gray-300 px-2 py-1 whitespace-nowrap">Attended Meeting*</th>
        <th class="border border-gray-300 px-2 py-1 whitespace-nowrap">Auth User</th>
        <th class="border border-gray-300 px-2 py-1 whitespace-nowrap">Tasked To</th>
        <th class="border border-gray-300 px-2 py-1">Notes</th>
        <th class="border border-gray-300 px-2 py-1 whitespace-nowrap">Timestamp</th>
        <th class="border border-gray-300 px-2 py-1"></th>
      </tr>
    </thead>
    <tbody>
      <% @mbr_call_me_actions.each do |ma| %>
      <tr class="odd:bg-white even:bg-gray-50">
        <td class="border border-gray-200 px-2 py-0.5">
          <a href="/r/member/show/<%= ma[:target_member_id] %>" class="text-blue-600 hover:underline">
            <span class="whitespace-nowrap"><%= ma[:target_member_name] %></span>
          </a>
        </td>
        <td class="border border-gray-200 px-2 py-0.5 text-center"><%= ma[:attended_meeting] ? 'Yes' : 'No' %></td>
        <td class="border border-gray-200 px-2 py-0.5 whitespace-nowrap"><%= ma[:a_user_name] %></td>
        <td class="border border-gray-200 px-2 py-0.5 whitespace-nowrap"><%= ma[:tasked_to] %></td>
        <td class="border border-gray-200 px-2 py-0.5 max-w-xs">
          <%= ma[:notes] %><% if ma[:has_logs] %> <em class="text-gray-400">More notes</em><% end %>
        </td>
        <td class="border border-gray-200 px-2 py-0.5 whitespace-nowrap"><%= ma[:ts] %></td>
        <td class="border border-gray-200 px-2 py-0.5 whitespace-nowrap text-xs">
          <a href="/m/member_action/add_note?mbr_action_id=<%= ma[:id] %>&type=<%= @action_type[:callme][:name] %>" class="text-blue-600 hover:underline">Add Note</a> |
          <a href="/m/mbr_callme/edit/<%= ma[:id] %>" class="text-blue-600 hover:underline">edit</a>
        </td>
      </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mb-6">
  <button onclick="document.getElementById('completed-callme').classList.toggle('hidden')"
          class="text-sm text-gray-600 border border-gray-300 rounded px-3 py-1 hover:bg-gray-100">
    Show / Hide Completed Call-Me Actions (<%= @completed_call_me_actions.size %>)
  </button>
</div>

<div id="completed-callme" class="hidden mb-8">
  <h3 class="text-lg font-semibold text-gray-700 mb-2">Completed Call-Me Actions</h3>
  <% if @completed_call_me_actions.empty? %>
    <p class="text-sm text-gray-500 mb-4">No completed call-me actions on record.</p>
  <% else %>
  <div class="overflow-x-auto">
    <table class="w-full border-collapse text-sm">
      <thead>
        <tr class="bg-gray-100 text-left">
          <th class="border border-gray-300 px-2 py-1">Member</th>
          <th class="border border-gray-300 px-2 py-1 whitespace-nowrap">Auth User</th>
          <th class="border border-gray-300 px-2 py-1 whitespace-nowrap">Tasked To</th>
          <th class="border border-gray-300 px-2 py-1">Notes</th>
          <th class="border border-gray-300 px-2 py-1 whitespace-nowrap">Timestamp</th>
          <th class="border border-gray-300 px-2 py-1"></th>
        </tr>
      </thead>
      <tbody>
        <% @completed_call_me_actions.each do |ma| %>
        <tr class="odd:bg-white even:bg-gray-50">
          <td class="border border-gray-200 px-2 py-0.5">
            <a href="/r/member/show/<%= ma[:target_member_id] %>" class="text-blue-600 hover:underline">
              <span class="whitespace-nowrap"><%= ma[:target_member_name] %></span>
            </a>
          </td>
          <td class="border border-gray-200 px-2 py-0.5 whitespace-nowrap"><%= ma[:a_user_name] %></td>
          <td class="border border-gray-200 px-2 py-0.5 whitespace-nowrap"><%= ma[:tasked_to] %></td>
          <td class="border border-gray-200 px-2 py-0.5 max-w-xs">
            <%= ma[:notes] %><% if ma[:has_logs] %> <em class="text-gray-400">More notes</em><% end %>
          </td>
          <td class="border border-gray-200 px-2 py-0.5 whitespace-nowrap"><%= ma[:ts] %></td>
          <td class="border border-gray-200 px-2 py-0.5 whitespace-nowrap text-xs">
            <% if ma[:has_logs] %>
              <a href="/m/member_action/add_note?mbr_action_id=<%= ma[:id] %>&type=<%= @action_type[:callme][:name] %>" class="text-blue-600 hover:underline">View Notes</a>
            <% end %>
          </td>
        </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <% end %>
</div>

